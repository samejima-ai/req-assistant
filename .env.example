# Gemini API キー
# Google AI Studio ( https://aistudio.google.com/apikey ) で取得してください
VITE_GEMINI_API_KEY=your_api_key_here

# Gemini モデル設定 (省略時はデフォルト値を使用)
# VITE_GEMINI_MODEL_CHAT=gemini-3.1-flash-lite-preview
# VITE_GEMINI_MODEL_DOC=gemini-3.1-flash-lite-preview
# VITE_GEMINI_MODEL_REVIEW_LIGHT=gemini-3-flash-preview
# VITE_GEMINI_MODEL_REVIEW_HEAVY=gemini-3.1-pro-preview

# Gemini 推論レベル設定 (low / medium / high)
# VITE_GEMINI_THINKING_CHAT=low
# VITE_GEMINI_THINKING_DOC=medium
# VITE_GEMINI_THINKING_REVIEW=medium
